# .env
# --- FastAPI 数据库连接配置 ---
DB_HOST=localhost
# 必须改为 3307，与 Docker 暴露的宿主机端口对应
DB_PORT=3307
# 统一使用 YiPack_ 命名
DB_USER=YiPack_admin
DB_PASSWORD=YiPack_admin_pwd
# 修正 YiHub 为 YiPack
DB_NAME=YiPack_erp

# --- Docker Compose MySQL 初始化配置 ---
# 保持与上方值一致，确保容器按此账号密码进行初始化
MYSQL_DATABASE=YiPack_erp
MYSQL_USER=YiPack_admin
MYSQL_PASSWORD=YiPack_admin_pwd
MYSQL_ROOT_PASSWORD=YiPack_root_secure_2026

# --- JWT 鉴权安全配置 ---
SECRET_KEY=KlfrIOVtHpOSLg==
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480