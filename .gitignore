# ==========================================
# 1. 核心安全红线 (绝对禁止提交)
# ==========================================
# .env
*.pem
*.key

# ==========================================
# 2. Python 环境与虚拟环境
# ==========================================
.venv/
venv/
ENV/
env/
bin/
lib/
# 编译文件
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/

# ==========================================
# 3. IDE 配置文件 (PyCharm & VSCode)
# ==========================================
.idea/
.vscode/
*.swp
*.swo

# ==========================================
# 4. Docker 与 本地数据库持久化数据
# ==========================================
# 忽略 docker-compose 产生的数据挂载目录，防止污染仓库
mysql_data/
redis_data/

# ==========================================
# 5. 系统级垃圾文件
# ==========================================
Thumbs.db
Desktop.ini
.DS_Store

# ==========================================
# 6. 项目特定：静态资源与临时文件
# ==========================================
# 生产环境中用户上传的图片应存放在专门的存储（如OSS），本地测试图不进代码库
app/static/uploads/*
!app/static/uploads/.gitkeep

# Alembic 迁移缓存
alembic/versions/*.pyc